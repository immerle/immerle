{
  "name": "immerle-app",
  "version": "0.1.0",
  "homepage": "https://github.com/immerle/immerle",
  "author": {
    "name": "Kilian SMITI",
    "email": "kilian@smiti.fr"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "gen:api": "openapi-typescript ../internal/api/docs/swagger.json -o src/api/generated/schema.ts",
    "export:web": "expo export --platform web && node -e \"require('fs').writeFileSync('dist/.gitkeep','')\"",
    "desktop": "electron electron/main.js",
    "desktop:dev": "concurrently -k -n web,electron \"npm run web\" \"wait-on tcp:8081 && npm run desktop\"",
    "desktop:pack": "npm run export:web && electron-builder --dir",
    "desktop:dist": "npm run export:web && electron-builder",
    "desktop:dist:mac": "npm run export:web && electron-builder --mac",
    "desktop:dist:win": "npm run export:web && electron-builder --win",
    "desktop:dist:linux": "npm run export:web && electron-builder --linux"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/slider": "4.5.5",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@shopify/flash-list": "1.7.3",
    "@tanstack/react-query": "5.66.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.0",
    "expo-file-system": "~18.0.0",
    "expo-font": "~13.0.4",
    "expo-image": "~2.0.0",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.0",
    "expo-localization": "~16.0.1",
    "expo-network": "~7.0.5",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.0",
    "i18n-js": "^4.5.3",
    "nativewind": "^4.1.23",
    "openapi-fetch": "^0.17.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-track-player": "^4.1.1",
    "react-native-web": "~0.19.13",
    "tailwindcss": "^3.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "fake-indexeddb": "^6.2.5",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.3.3",
    "wait-on": "^8.0.1"
  },
  "private": true,
  "overrides": {
    "undici": "^6.27.0"
  }
}
