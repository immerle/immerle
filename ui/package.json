{
  "name": "immerle-app",
  "version": "0.1.0",
  "homepage": "https://github.com/immerle/immerle",
  "author": {
    "name": "Kilian SMITI",
    "email": "kilian@smiti.fr"
  },
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "gen:api": "openapi-typescript ../internal/api/docs/swagger.json -o src/api/generated/schema.ts",
    "export:web": "expo export --platform web && node -e \"require('fs').writeFileSync('dist/.gitkeep','')\"",
    "desktop": "electron electron/main.js",
    "desktop:dev": "concurrently -k -n web,electron \"npm run web\" \"wait-on tcp:8081 && npm run desktop\"",
    "desktop:pack": "npm run export:web && electron-builder --dir",
    "desktop:dist": "npm run export:web && electron-builder",
    "desktop:dist:mac": "npm run export:web && electron-builder --mac",
    "desktop:dist:win": "npm run export:web && electron-builder --win",
    "desktop:dist:linux": "npm run export:web && electron-builder --linux"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@shopify/flash-list": "1.7.6",
    "@tanstack/react-query": "5.66.0",
    "expo": "54",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.9",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "i18n-js": "^4.5.3",
    "nativewind": "^4.2.6",
    "openapi-fetch": "^0.17.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-track-player": "^4.1.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "fake-indexeddb": "^6.2.5",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "openapi-typescript": "^7.13.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.1"
  },
  "private": true,
  "overrides": {
    "undici": "^6.27.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "@shopify/flash-list"
      ]
    }
  }
}
