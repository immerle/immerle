                    "id": {
                        "type": "string"
                    },
                    "itemId": {
                        "type": "string"
                    },
                    "itemType": {
                        "example": "track",
                        "type": "string"
                    },
                    "privacy": {
                        "example": "friends",
                        "type": "string"
                    },
                    "type": {
                        "example": "listen",
                        "type": "string"
                    },
                    "userId": {
                        "type": "string"
                    },
                    "username": {
                        "example": "bob",
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "immerle.ActivityResponse": {
                "properties": {
                    "events": {
                        "items": {
