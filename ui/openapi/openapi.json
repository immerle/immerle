                        "example": "1.0.0",
                        "type": "string"
                    },
                    "server": {
                        "example": "immerle",
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "immerle.CapabilityDTO": {
                "properties": {
                    "version": {
                        "example": 1,
                        "type": "integer"
                    }
                },
                "type": "object"
            },
            "immerle.ErrorResponse": {
                "properties": {
                    "error": {
                        "example": "already_initialized",
                        "type": "string"
                    },
                    "ok": {
                        "example": false,
