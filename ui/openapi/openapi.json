    "info": {
        "contact": {
            "name": "immerle"
        },
        "description": "Native immerle endpoints (first-run setup, capability\ndiscovery, friends, activity feed, collaborative playlists and\nsynchronized Jam sessions) that complement the Subsonic /\nOpenSubsonic API served under /rest/.\n\nAuthenticated endpoints reuse Subsonic credentials passed as\nquery parameters: u (username) plus either p (password) or the\ntoken pair t (md5(password+salt)) and s (salt), and c (client\nname). Setup and capability endpoints are unauthenticated.",
        "license": {
            "name": "See repository"
        },
        "title": "immerle extension API",
        "version": "1.0.0"
    },
    "externalDocs": {
        "description": "",
        "url": ""
    },
    "paths": {
        "/activity": {
            "get": {
                "description": "Returns activity events visible to the caller, honoring each author's privacy setting.",
                "parameters": [
                    {
                        "description": "Subsonic username",
                        "in": "query",
                        "name": "u",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Subsonic password (or t+s token auth)",
                        "in": "query",
                        "name": "p",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "description": "Client name",
                        "in": "query",
                        "name": "c",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/immerle.ActivityResponse"
                                }
                            }
                        },
                        "description": "OK"
                    }
                },
                "summary": "Activity feed",
                "tags": [
                    "activity"
                ]
            }
        },
        "/capabilities": {
            "get": {
                "description": "Unauthenticated. Lets clients detect supported immerle extensions and whether first-run setup is still needed.",
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/immerle.CapabilitiesResponse"
                                }
                            }
