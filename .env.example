# immerle-server BOOTSTRAP configuration.
#
# Copy to `.env` (auto-loaded at startup; real environment variables take
# precedence). These few settings need a RESTART to change. Everything else —
# the providers (incl. built-in credentials) & their behaviour, artist avatars,
# scan cadence, transcoding, CORS, device-token TTL, federation — is managed at
# RUNTIME by an admin via the API (GET/POST /admin/settings, /admin/providers,
# /admin/cleanup) and stored in data/configuration.yaml.

# --- HTTP server ---
# Listen port (bare number).
PORT=4533

# --- Auth ---
# Optional. If unset, a random secret is generated at startup and stored in
# data/configuration.yaml — so you normally don't need to set this.
# AUTH_SECRET=
# Gate first-run admin creation behind a one-time startup token.
AUTH_REQUIRE_SETUP_TOKEN=false

# --- Database ---
DATABASE_DRIVER=sqlite
DATABASE_DSN=immerle.db
# For Postgres:
#   DATABASE_DRIVER=postgres
#   DATABASE_DSN=postgres://immerle:immerle@localhost:5432/immerle?sslmode=disable

# --- Logging ---
LOG_LEVEL=info     # debug | info | warn | error
# Output is always structured JSON, streamable live from the admin UI.

# --- Library (paths only; scan-on-start is always on, cadence/watch are runtime) ---
LIBRARY_PATHS=/music
LIBRARY_DATA_DIR=data

# --- Federation hub (dev only) ---
# The hub URL is hardcoded (https://hub.immerle.com) and NOT admin-editable.
# Set this to point an instance at a local hub while debugging. Works here in
# .env or as a real environment variable (a real env var takes precedence).
# DEV_IMMERLE_HUB_URL=http://localhost:8080

# Providers (including built-ins like jamendo and their credentials) are NOT set
# here — they are configured via the admin API (POST /admin/providers). For
# example jamendo is seeded disabled with a {"client_id":"<JAMENDO_TOKEN>"} config
# to fill in and enable from the UI.
