# immerle-server BOOTSTRAP configuration.
#
# Copy to `.env` (auto-loaded at startup; real environment variables take
# precedence). These are the settings that need a RESTART to change. Everything
# else — provider behaviour, artist avatars, scan cadence, federation — is
# managed at RUNTIME by an admin via the API (GET/POST /admin/settings,
# /admin/providers, /admin/cleanup) and stored in the database.

# --- HTTP server ---
IMMERLE_SERVER__ADDRESS=:4533
# Comma-separated browser origins allowed via CORS ("*" allows any).
IMMERLE_SERVER__CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
IMMERLE_SERVER__SHUTDOWN_TIMEOUT=15s

# --- Auth ---
# MUST be a stable, secret value in production (encrypts stored passwords + signs tokens).
IMMERLE_AUTH__SECRET=change-me-in-production
# Gate first-run admin creation behind a one-time startup token.
IMMERLE_AUTH__REQUIRE_SETUP_TOKEN=false
# Device-session JWT lifetime (0 = never expires; revoke via the devices registry).
IMMERLE_AUTH__DEVICE_TOKEN_TTL=720h

# --- Database ---
IMMERLE_DATABASE__DRIVER=sqlite
IMMERLE_DATABASE__DSN=immerle.db
# For Postgres:
#   IMMERLE_DATABASE__DRIVER=postgres
#   IMMERLE_DATABASE__DSN=postgres://immerle:immerle@localhost:5432/immerle?sslmode=disable

# --- Logging ---
IMMERLE_LOG__LEVEL=info     # debug | info | warn | error
IMMERLE_LOG__FORMAT=text    # text | json

# --- Library (paths are bootstrap; scan cadence/watch are runtime settings) ---
IMMERLE_LIBRARY__PATHS=/music
IMMERLE_LIBRARY__DATA_DIR=data
IMMERLE_LIBRARY__SCAN_ON_START=true

# --- Transcoding ---
IMMERLE_TRANSCODE__FFMPEG_PATH=ffmpeg
IMMERLE_TRANSCODE__FFPROBE_PATH=ffprobe

# --- On-demand subsystem switch (the providers themselves are admin-managed) ---
IMMERLE_PROVIDERS__ENABLED=false
# Built-in provider credentials (only for compiled-in providers like jamendo):
#   IMMERLE_PROVIDERS__SETTINGS__JAMENDO__CLIENT_ID=your-key
