# gossignol-server BOOTSTRAP configuration.
#
# Copy to `.env` (auto-loaded at startup; real environment variables take
# precedence). These are the settings that need a RESTART to change. Everything
# else — provider behaviour, artist avatars, scan cadence, federation — is
# managed at RUNTIME by an admin via the API (GET/POST /admin/settings,
# /admin/providers, /admin/cleanup) and stored in the database.

# --- HTTP server ---
GOSSIGNOL_SERVER__ADDRESS=:4533
# Comma-separated browser origins allowed via CORS ("*" allows any).
GOSSIGNOL_SERVER__CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
GOSSIGNOL_SERVER__SHUTDOWN_TIMEOUT=15s

# --- Auth ---
# MUST be a stable, secret value in production (encrypts stored passwords + signs tokens).
GOSSIGNOL_AUTH__SECRET=change-me-in-production
# Gate first-run admin creation behind a one-time startup token.
GOSSIGNOL_AUTH__REQUIRE_SETUP_TOKEN=false
# Device-session JWT lifetime (0 = never expires; revoke via the devices registry).
GOSSIGNOL_AUTH__DEVICE_TOKEN_TTL=720h

# --- Database ---
GOSSIGNOL_DATABASE__DRIVER=sqlite
GOSSIGNOL_DATABASE__DSN=gossignol.db
# For Postgres:
#   GOSSIGNOL_DATABASE__DRIVER=postgres
#   GOSSIGNOL_DATABASE__DSN=postgres://gossignol:gossignol@localhost:5432/gossignol?sslmode=disable

# --- Logging ---
GOSSIGNOL_LOG__LEVEL=info     # debug | info | warn | error
GOSSIGNOL_LOG__FORMAT=text    # text | json

# --- Library (paths are bootstrap; scan cadence/watch are runtime settings) ---
GOSSIGNOL_LIBRARY__PATHS=/music
GOSSIGNOL_LIBRARY__DATA_DIR=data
GOSSIGNOL_LIBRARY__SCAN_ON_START=true

# --- Transcoding ---
GOSSIGNOL_TRANSCODE__FFMPEG_PATH=ffmpeg
GOSSIGNOL_TRANSCODE__FFPROBE_PATH=ffprobe

# --- On-demand subsystem switch (the providers themselves are admin-managed) ---
GOSSIGNOL_PROVIDERS__ENABLED=false
# Built-in provider credentials (only for compiled-in providers like jamendo):
#   GOSSIGNOL_PROVIDERS__SETTINGS__JAMENDO__CLIENT_ID=your-key
